      "Bash(git clean -fx*)",
      "Bash(git clean -fdx*)",
      "Bash(git checkout -- *)",
      "Bash(git checkout .)",
      "Bash(git checkout . *)",
      "Bash(git restore --staged*)",
      "Bash(git branch -D *)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit -m * --no-verify*)",
      "Bash(git commit -am * --no-verify*)",
      "Bash(git push --no-verify*)",
      "Bash(* DROP TABLE *)",
      "Bash(* DROP DATABASE *)",
      "Bash(* TRUNCATE *)",
      "Bash(mysql * -e *DROP*)",
      "Bash(mysql * -e *TRUNCATE*)",
      "Bash(psql * -c *DROP*)",
      "Bash(psql * -c *TRUNCATE*)"
    ]
  }
