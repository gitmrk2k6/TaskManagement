{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(tree*)",
      "Bash(wc *)",
