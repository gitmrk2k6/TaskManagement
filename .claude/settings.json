      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch)",
      "Bash(git branch --list*)",
      "Bash(git blame*)",
      "Bash(git remote -v)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git commit -am *)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push)",
      "Bash(git push origin *)",
      "Bash(git stash*)",
      "Bash(git init*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr status*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh repo view*)",
      "Bash(gh auth status)",
      "Bash(gh api *)",
      "Bash(mvn *)",
      "Bash(./mvnw *)",
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(java -version)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(jar *)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm ci)",
      "Bash(npm list*)",
      "Bash(node *)",
      "Bash(docker ps*)",
      "Bash(docker logs*)",
      "Bash(docker images*)",
      "Bash(mkdir -p *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm -f *)",
      "Bash(mv *)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git clean -f*)",
